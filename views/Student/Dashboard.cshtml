@model DemoRepository
@{
    ViewData["Title"] = "لوحة الطالب";
}
<section class="page-head dashboard-head">
    <div>
        <h1>لوحة تحكم الطالب</h1>
        <p>ملخص الطلبات، التقدم، المواعيد، والخبراء المسؤولين.</p>
    </div>
    <a class="btn primary" asp-controller="Home" asp-action="Contact">طلب جديد</a>
</section>
<section class="stats wide">
    <div><strong>@Model.Orders.Count</strong><span>طلبات نشطة</span></div>
    <div><strong>@Model.Orders.Average(o => o.Progress).ToString("0")%</strong><span>متوسط الإنجاز</span></div>
    <div><strong>@Model.Experts.Count</strong><span>خبراء متاحون</span></div>
</section>
<section class="section">
    <h2>طلباتي الحالية</h2>
    <div class="table-card">
        <table>
            <thead><tr><th>رقم</th><th>الخدمة</th><th>التخصص</th><th>الخبير</th><th>الحالة</th><th>التقدم</th><th>الموعد</th></tr></thead>
            <tbody>
            @foreach (var order in Model.Orders)
            {
                <tr>
                    <td>#@order.Id</td>
                    <td>@order.ServiceName</td>
                    <td>@order.Specialty</td>
                    <td>@order.ExpertName</td>
                    <td><span class="status">@order.Status</span></td>
                    <td><div class="progress mini"><span style="width:@order.Progress%"></span></div></td>
                    <td>@order.DueDate.ToString("yyyy/MM/dd")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
